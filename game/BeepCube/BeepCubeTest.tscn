[ext_resource type="PackedScene" uid="uid://dvj8dorx2l7s0" path="res://game/BeepCube/BeepCube.tscn" id="1_o0b4s"]
[ext_resource type="Script" path="res://game/scripts/BeepSaberController.gd" id="3_3o1m2"]
